package Selenium;

import java.time.Duration;
import java.util.ArrayList;
import java.util.List;

import org.openqa.selenium.By;
import org.openqa.selenium.JavascriptExecutor;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.interactions.Actions;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class SeleniumPrac {

	public static void main(String[] args) throws InterruptedException {
		
		
		
		// Step 1: Open browser
        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

        // Step 2: Open the URL
        driver.get("https://www.schoolmykids.com/");
		
        
        //step 3: Hover over Schools menu using actions.
        
        WebElement schoolsMenu = driver.findElement(By.xpath("//button[contains(text(),'Schools')]"));
        Actions actions = new Actions(driver);
        actions.moveToElement(schoolsMenu).perform();  
		
     // Step 4: Click "Pune" under Best Schools In
        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(30));
        WebElement puneOption = wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.xpath("//a[@class='dropdown-item' and text()='Pune']")));
        puneOption.click();
        
        
     
        
     // Step 5: Locate the CBSE checkbox
        WebElement cbseCheckbox = wait.until(ExpectedConditions.visibilityOfElementLocated(By.id("board_cbse")));
        

        //  Create JavascriptExecutor from driver
        JavascriptExecutor js = (JavascriptExecutor) driver;
        
        

        js.executeScript("arguments[0].click();", cbseCheckbox);
        
        Thread.sleep(2000);
        
        
      // Step 6 :   Scrolls to the bottom of the page to ensure results are loaded. 
        js.executeScript("window.scrollTo(0,document.body.scrollHeight)");
        
        Thread.sleep(3000);
        
        js.executeScript("window.scrollBy(0,-document.body.scrollHeight)");

        Thread.sleep(3000);
    
     // Step 7 : Verify search results are displayed
        
     //  Waits until all school result elements are visible. and Stores them in a list.

 
        List<WebElement> schoolResults = wait.until(ExpectedConditions.visibilityOfAllElementsLocatedBy(By.xpath("//h3[@class='custom-card-title lising-title d-inline-block']/span")));

        if (schoolResults.size() > 0) {
            System.out.println(" Search results are displayed.");
        } else {
            System.out.println(" No search results found.");
        }
   
        
     // schoolResults was already declared above
        
     // Step 8 : Extracts the text (school name), and stores it in a list.
        List<String> schoolNames = new ArrayList<>();
        for (WebElement school : schoolResults) {
            schoolNames.add(school.getText());
        }

        // Print the list
        System.out.println("Schools found on first page:");
        for (String name : schoolNames) {
            System.out.println(name);
        }    

        
     // After printing the school names

     // Close the browser  after execution.
        driver.quit();

        
        
        
        
        
        
        
        
        
        
        
        
        
        
        
	}
}
		
		













		

		
		   
		

		
		
